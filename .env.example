# Copia este archivo a .env y rellena con valores reales.
# .env NUNCA se commitea (ver .gitignore). Este archivo solo lleva placeholders evidentes.

# --- Entorno ---
# development: cookie de refresh sin flag Secure (necesario para HTTP local).
# production: Secure=True obligatorio (ver docs/adr/0002).
ENVIRONMENT=development

# --- APIs externas ---
TMDB_API_KEY=changeme
OMDB_API_KEY=changeme

# --- PostgreSQL ---
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cine_platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Redpanda (API compatible con Kafka) ---
REDPANDA_BROKERS=localhost:9092

# --- Auth (JWT) ---
JWT_SECRET=changeme
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# --- Email dev (Mailpit) ---
SMTP_HOST=localhost
SMTP_PORT=1025

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=changeme
MINIO_ROOT_PASSWORD=changeme

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# --- Ollama (LLM local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Ingestion (Fase 0.1) ---
# Alcance por defecto del backfill en desarrollo local (subconjunto acotado de IDs).
# El backfill completo real se lanza explicitamente con --full, no por defecto.
INGESTION_DEV_BACKFILL_LIMIT=10000
