# Data / artifacts (nunca versionar datos crudos ni artifacts de modelos en git)
data/
*.parquet
mlruns/
mlartifacts/

# IDE / OS
.vscode/
.idea/
.DS_Store

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Cassettes de VCR (fixtures grabadas) SI se versionan explicitamente en tests/fixtures/
