# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.uv/
uv.lock.bak

# Env / secrets
.env
!.env.example
*.pem
*.key

# Terraform
infra/terraform/**/.terraform/
infra/terraform/**/terraform.tfstate
